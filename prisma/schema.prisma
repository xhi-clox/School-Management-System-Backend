generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("Student") // Default role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  parent    Parent?
}

model Parent {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  students  Student[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id            String   @id @default(cuid())
  name          String
  admissionNo   String   @unique
  class         String
  section       String
  roll          Int
  gender        String
  bloodGroup    String?
  religion      String?
  banglaName    String?
  dob           DateTime?
  guardianPhone String?
  guardianEmail String?
  fatherName    String?
  motherName    String?
  phone         String?
  email         String?
  nationality   String?
  medicalNote   String?
  additionalNote String?
  birthCertNo   String?
  siblingsCount Int?
  address       String?
  academicYear  String?
  shift         String?
  avatar        String?
  status        String   @default("pending_payment")
  admissionDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  fees          StudentFee[]
  attendance    Attendance[]
  results       Result[]
  invoices      Invoice[]
  assignments   StudentFeeAssignment[]
  sales         Sale[]
  guardian      Guardian?
  login         StudentLogin?
  parentId      String?
  parent        Parent?  @relation(fields: [parentId], references: [id])
}

model Guardian {
  id                String   @id @default(cuid())
  studentId         String   @unique
  fatherName        String?
  fatherPhone       String?
  fatherOccupation  String?
  motherName        String?
  motherPhone       String?
  motherOccupation  String?
  guardianName      String?
  guardianPhone     String?
  guardianRelation  String?
  guardianAddress   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model StudentLogin {
  id        String   @id @default(cuid())
  studentId String   @unique
  username  String   @unique
  password  String
  role      String   @default("Student")
  status    String   @default("Active")
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model TeacherLogin {
  id        String   @id @default(cuid())
  teacherId String   @unique
  username  String   @unique
  password  String
  role      String   @default("Teacher")
  status    String   @default("Active")
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model AdmissionPackage {
  id          String   @id @default(cuid())
  name        String
  session     String
  classId     String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  class       SchoolClass @relation(fields: [classId], references: [id])
  feeItems    AdmissionFeeItem[]
}

model AdmissionFeeItem {
  id          String   @id @default(cuid())
  packageId   String
  name        String
  amount      Float
  isMandatory Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  package     AdmissionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
}

model Invoice {
  id           String   @id @default(cuid())
  studentId    String
  type         String   // 'admission', 'tuition', etc.
  totalAmount  Float
  paidAmount   Float    @default(0)
  status       String   // 'unpaid', 'partial', 'paid'
  dueDate      DateTime?
  billingMonth String?  // 'YYYY-MM'
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  items        InvoiceItem[]
  payments     Payment[]
}

model InvoiceItem {
  id        String   @id @default(cuid())
  invoiceId String
  name      String
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String   @id @default(cuid())
  invoiceId      String
  amount         Float
  method         String
  transactionRef String?
  receivedBy     String?
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model LedgerEntry {
  id               String   @id @default(cuid())
  type             String   // 'income', 'expense'
  category         String
  amount           Float
  referenceInvoice String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Product {
  id             String   @id @default(cuid())
  name           String
  category       String?
  purchasePrice  Float
  sellingPrice   Float
  currentStock   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  purchaseItems  PurchaseItem[]
  saleItems      SaleItem[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  purchases Purchase[]
}

model Purchase {
  id           String         @id @default(cuid())
  supplierId   String?
  purchaseDate DateTime       @default(now())
  totalCost    Float          @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  supplier     Supplier?      @relation(fields: [supplierId], references: [id])
  items        PurchaseItem[]
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  productId   String
  quantity    Int
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
}

model Sale {
  id            String     @id @default(cuid())
  studentId     String?
  saleDate      DateTime   @default(now())
  totalAmount   Float      @default(0)
  paymentStatus String     @default("unpaid")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  student       Student?   @relation(fields: [studentId], references: [id])
  items         SaleItem[]
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}

model Teacher {
  id         String   @id @default(cuid())
  name       String
  employeeId String   @unique
  subject    String
  email      String   @unique
  phone      String
  avatar     String?
  status     String   @default("Active")
  designation String  @default("Teacher")
  joiningDate DateTime?
  salary      Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  salaries   TeacherSalary[]
  attendance TeacherAttendance[]
  classes    SchoolClass[]
  login      TeacherLogin?
}

model Staff {
  id         String   @id @default(cuid())
  name       String
  employeeId String   @unique
  designation String
  department String?
  email      String?  @unique
  phone      String
  avatar     String?
  status     String   @default("Active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  salaries   StaffSalary[]
}

model StudentFee {
  id         String   @id @default(cuid())
  studentId  String
  feeType    String
  amount     Float
  discount   Float    @default(0)
  status     String   @default("Due")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model TeacherSalary {
  id          String   @id @default(cuid())
  teacherId   String
  baseSalary  Float
  bonus       Float    @default(0)
  deductions  Float    @default(0)
  netSalary   Float
  paymentDate DateTime
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
}

model StaffSalary {
  id          String   @id @default(cuid())
  staffId     String
  baseSalary  Float
  bonus       Float    @default(0)
  deductions  Float    @default(0)
  netSalary   Float
  paymentDate DateTime
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  staff       Staff    @relation(fields: [staffId], references: [id])
}

model SchoolExpense {
  id        String   @id @default(cuid())
  category  String
  amount    Float
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchoolClass {
  id        String   @id @default(cuid())
  name      String
  section   String
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  packages  AdmissionPackage[]
  feeStructures FeeStructure[]
  examSchedules ExamSchedule[]
}

model FeeStructure {
  id         String      @id @default(cuid())
  name       String
  classId    String?
  amount     Float
  frequency  String      @default("monthly")
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  class      SchoolClass? @relation(fields: [classId], references: [id])
  assignments StudentFeeAssignment[]
}

model StudentFeeAssignment {
  id              String       @id @default(cuid())
  studentId       String
  feeStructureId  String
  discountPercent Float        @default(0)
  customAmount    Float?
  startMonth      Int
  startYear       Int
  endMonth        Int?
  endYear         Int?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure    FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  @@index([studentId, isActive])
}

model Subject {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  type      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schedules ExamSchedule[]
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  date      DateTime
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
}

model TeacherAttendance {
  id        String   @id @default(cuid())
  teacherId String
  date      DateTime
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teacher   Teacher  @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, date])
}

model ExamType {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., 'Semester', 'CT', 'Midterm', 'Final'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  exams       Exam[]
  gradingRules GradingSystem[]
}

model Exam {
  id          String   @id @default(cuid())
  name        String
  typeId      String   @default("") // Link to ExamType
  type        ExamType @relation(fields: [typeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  academicYear String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  results       Result[]
  schedules     ExamSchedule[]
}

model Result {
  id        String   @id @default(cuid())
  studentId String
  examId    String
  subjectId String
  
  // Broken down marks
  ct        Float    @default(0) // Class Test
  cwhw      Float    @default(0) // CW & HW
  dgc       Float    @default(0) // D & GC
  written   Float    @default(0)
  mcq       Float    @default(0)
  practical Float    @default(0)
  
  totalMarks   Float    @default(0)
  grade        String?  // LG (Letter Grade)
  gp           Float?   // GP (Grade Point)
  highestMarks Float    @default(0)
  
  createdAt    DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam      Exam     @relation(fields: [examId], references: [id])

  @@unique([studentId, examId, subjectId])
}

model ExamSchedule {
  id        String   @id @default(cuid())
  examId    String
  classId   String?
  subjectId String
  date      DateTime
  startTime String
  endTime   String
  fullMarks Int?
  passMarks Int?
  roomNo    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  exam      Exam     @relation(fields: [examId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  class     SchoolClass? @relation(fields: [classId], references: [id])

  @@unique([examId, subjectId, classId])
}

model GradingSystem {
  id           String   @id @default(cuid())
  grade        String
  minPercent   Float
  maxPercent   Float
  gp           Float    @default(0) // Grade Point
  status       String   // 'PASS' or 'FAIL'
  
  examTypeId   String   @default("")
  examType     ExamType @relation(fields: [examTypeId], references: [id])
  
  writtenPass  Float?
  mcqPass      Float?
  totalPass    Float?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Institute {
  id          String   @id @default(cuid())
  name        String   @default("NexGrad Institute")
  logo        String?
  targetLine  String?  @default("Excellence in Education")
  phone       String?
  website     String?
  address     String?
  country     String?
  email       String   @unique
  currency    String   @default("USD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeeParticular {
  id        String   @id @default(cuid())
  label     String
  amount    Float?   // null for FIXED fields
  isFixed   Boolean  @default(false)
  target    String   @default("All Students")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
